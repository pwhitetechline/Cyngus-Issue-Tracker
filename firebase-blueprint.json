{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "format": "url", "description": "The user's photo URL" },
        "role": { "type": "string", "enum": ["ADMIN", "REPORTER", "ASSIGNEE", "VIEWER"], "description": "The user's role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt"]
    },
    "Issue": {
      "title": "Issue",
      "description": "A bug, feature request, or suggestion",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["BUG", "FEATURE", "SUGGESTION"] },
        "status": { "type": "string", "enum": ["OPEN", "IN_PROGRESS", "IN_REVIEW", "RESOLVED", "CLOSED"] },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "reporterId": { "type": "string" },
        "assigneeId": { "type": "string" },
        "labels": { "type": "array", "items": { "type": "string" } },
        "attachments": { "type": "array", "items": { "$ref": "Attachment" } },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "type", "status", "priority", "reporterId", "createdAt", "updatedAt"]
    },
    "Attachment": {
      "title": "Attachment",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "url" }
      },
      "required": ["name", "url"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on an issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "issueId": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "mentions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["issueId", "userId", "content", "createdAt"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "A log of changes to an issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "issueId": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "oldValue": { "type": "object" },
        "newValue": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["issueId", "userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/issues/{issueId}": {
      "schema": "Issue",
      "description": "Issue tracking documents"
    },
    "/issues/{issueId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on specific issues"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "System-wide audit logs"
    }
  }
}
